// prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"] 
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. ตาราง "เกม" (Game)
model Game {
  id        Int       @id @default(autoincrement())
  title     String    // ชื่อเกม
  imageUrl  String    // รูปปก
  slug      String    @unique // ชื่อย่อ URL (เช่น rov, valorant)
  order     Int       @default(0)
  products  Product[] 
// ✅ เพิ่มบรรทัดนี้ครับ! เพื่อให้รู้ว่าเกมนี้มีคูปองอะไรบ้าง
  coupons   Coupon[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// 2. ตาราง "แพ็กเกจสินค้า" (Product)
model Product {
  id        Int       @id @default(autoincrement())
  name      String    // ชื่อแพ็กเกจ
   
  // ราคาขายหน้าร้าน
  price     Decimal   @db.Decimal(10, 2)   

  // ต้นทุน
  cost      Decimal   @default(0) @db.Decimal(10, 2) 

  imageUrl  String?   // รูปไอคอน
    
  gameId    Int       
  game      Game      @relation(fields: [gameId], references: [id])

  orders    Order[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// 3. ตาราง User (คนใช้งาน)
model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique // ใช้สำหรับ Login
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // เก็บระหัสผ่าน (Hash)
    
  role          String    @default("USER") // "USER" หรือ "ADMIN"
    
  // ระบบกัน Brute Force
  loginAttempts Int       @default(0)      
  lockedUntil   DateTime?                  

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  orders        Order[]       // ประวัติการสั่งซื้อ
  couponUsages  CouponUsage[] // ประวัติการใช้คูปอง
  resetToken       String?   // เก็บตั๋วผ่านทางสำหรับรีเซ็ตรหัส
  resetTokenExpiry DateTime? // เก็บเวลาหมดอายุของตั๋ว (เช่น 15 นาที)
}

// 4. ตาราง Account (NextAuth)
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// 5. ตาราง Session (NextAuth)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 6. ตาราง Order (ออเดอร์สั่งซื้อ)
model Order {
  id        Int      @id @default(autoincrement())
  token     String   @unique @default(uuid()) // เลขอ้างอิงออเดอร์
  status    String   @default("PENDING") // PENDING, PAID, COMPLETED, ISSUE, CANCELLED
    
  // ข้อมูลสินค้า
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  
  // เก็บ JSON ข้อมูลเพิ่มเติม (เช่น คูปองที่ใช้, ข้อมูลเกมที่กรอก)
  data      String?  @db.Text
  
  // Snapshot ราคาและต้นทุน (เอาไว้คำนวณกำไรย้อนหลัง)
  price     Decimal  @default(0) @db.Decimal(10, 2)  
  cost      Decimal  @default(0) @db.Decimal(10, 2)  
couponCode String?
  // ข้อมูลเกมที่ลูกค้ากรอกมา
  uid             String?
  username        String?
  password        String?
  email           String?   // เผื่อบางเกมใช้อีเมล
  note            String?   @db.Text 
  adminMessage    String?   @db.Text 
  adminImageUrl   String?   // เพิ่มช่องนี้สำหรับเก็บรูปที่แอดมินส่ง
  // รูปสลิป
  imageUrl        String?   @db.Text 
    slipRef         String?   @unique
  // Roblox 2-Step
  twoFactorCode   String?   

  // ผูกกับ User
  userId     String      
  user       User      @relation(fields: [userId], references: [id])

  // ระบบแชท
  messages   OrderMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 7. ตาราง OrderMessage
model OrderMessage {
  id        Int      @id @default(autoincrement())
  message   String?  // ข้อความ
  imageUrl  String?  @db.Text 
  isAdmin   Boolean  @default(false) 
    
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// 8. Promotion
model Promotion {
  id          Int      @id @default(autoincrement())
  imageUrl    String
  title       String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// 9. Coupon (ระบบคูปอง)
model Coupon {
  id        Int      @id @default(autoincrement())
  code      String   @unique // รหัสโค้ด เช่น SAVE10
  discount  Int      // ลดกี่บาท
  limit     Int      // ใช้ได้กี่ครั้ง
  used      Int      @default(0) // ใช้ไปแล้วกี่ครั้ง
  isActive  Boolean  @default(true) // เปิด/ปิด โค้ด
  // ✅ เพิ่ม 2 บรรทัดนี้ครับ
  minPrice  Int      @default(0)  // ยอดซื้อขั้นต่ำ (ถ้า 0 คือไม่มีขั้นต่ำ)
  gameId    Int?                  // ใช้ได้เฉพาะเกม ID นี้ (ถ้า null คือใช้ได้ทุกเกม)
  
  // เชื่อม Relation กับ Game (เผื่อดึงชื่อเกมมาโชว์)
  game      Game?    @relation(fields: [gameId], references: [id])
  createdAt DateTime @default(now()) // ✅ เพิ่มแล้ว (จำเป็นสำหรับการเรียงลำดับ)
  
  // ประวัติการใช้โค้ด
  usages    CouponUsage[]
}

// 10. CouponUsage (ประวัติการใช้)
model CouponUsage {
  id        Int      @id @default(autoincrement())
  
  // เชื่อมกับ User จริงๆ
  userId    String 
  user      User     @relation(fields: [userId], references: [id])

  // เชื่อมกับ Coupon
  couponId  Int
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  
  usedAt    DateTime @default(now()) // บันทึกเวลาที่กดใช้
}
model StoreSetting {
  id        Int     @id @default(1)
  
  // โหมดของร้าน: "OPEN" (เปิดตลอด), "CLOSED" (ปิดบังคับ), "AUTO" (ตามเวลา)
  mode      String  @default("AUTO") 
  
  openTime  String  @default("10:00") // เวลาเปิดออโต้
  closeTime String  @default("00:00") // เวลาปิดออโต้
  
  message   String? @default("ร้านปิดให้บริการชั่วคราว เปิดทำการ 10:00 - 00:00 น.") 
}